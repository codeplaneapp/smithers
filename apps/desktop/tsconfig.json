{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "types": ["bun-types"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
