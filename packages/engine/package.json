{
  "name": "@smithers/engine",
  "version": "0.0.0",
  "description": "Concrete Smithers workflow execution engine",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/core": "workspace:*",
    "@smithers/graph": "workspace:*",
    "@smithers/runtime": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/react": "workspace:*",
    "@smithers/react-reconciler": "workspace:*",
    "@smithers/db": "workspace:*",
    "@smithers/agents": "workspace:*",
    "@smithers/tools": "workspace:*",
    "@smithers/scorers": "workspace:*",
    "@smithers/memory": "workspace:*",
    "@smithers/sandbox": "workspace:*",
    "@smithers/time-travel": "workspace:*",
    "@smithers/vcs": "workspace:*",
    "@smithers/voice": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
