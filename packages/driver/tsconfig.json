{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "smithers",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": [
      "bun-types"
    ],
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "smithers/jsx-runtime": [
        "../smithers/src/jsx-runtime.js"
      ],
      "smithers/jsx-dev-runtime": [
        "../smithers/src/jsx-runtime.js"
      ],
      "@smithers/react-reconciler/*": [
        "../react-reconciler/src/*.js"
      ],
      "@smithers/scheduler/*": [
        "../scheduler/src/*.js"
      ],
      "@smithers/graph": [
        "../graph/src/index.js"
      ],
      "@smithers/graph/*": [
        "../graph/src/*.js"
      ],
      "@smithers/errors/*": [
        "../errors/src/*.js"
      ],
      "@smithers/db/*": [
        "../db/src/*.js"
      ],
      "@smithers/observability/*": [
        "../../apps/observability/src/*.js"
      ]
    },
    "allowJs": true
  },
  "include": [
    "src/**/*"
  ]
}
