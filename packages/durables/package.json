{
  "name": "@smithers/durables",
  "version": "0.0.0",
  "description": "Durable workflow primitives: approvals, timers, events, continue-as-new, and human requests",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./ApprovalResolution": {
      "types": "./src/ApprovalResolution.ts",
      "default": "./src/ApprovalResolution.ts"
    },
    "./ContinueAsNewTransition": {
      "types": "./src/ContinueAsNewTransition.ts",
      "default": "./src/ContinueAsNewTransition.ts"
    },
    "./DurablePrimitives": {
      "types": "./src/DurablePrimitives.ts",
      "default": "./src/DurablePrimitives.ts"
    },
    "./DurablePrimitivesLive": {
      "types": "./src/DurablePrimitivesLive.ts",
      "default": "./src/DurablePrimitivesLive.ts"
    },
    "./DurablePrimitivesService": {
      "types": "./src/DurablePrimitivesService.ts",
      "default": "./src/DurablePrimitivesService.ts"
    },
    "./TimerRequest": {
      "types": "./src/TimerRequest.ts",
      "default": "./src/TimerRequest.ts"
    },
    "./HUMAN_REQUEST_KINDS": {
      "types": "./src/HUMAN_REQUEST_KINDS.ts",
      "default": "./src/HUMAN_REQUEST_KINDS.ts"
    },
    "./HumanRequestKind": {
      "types": "./src/HumanRequestKind.ts",
      "default": "./src/HumanRequestKind.ts"
    },
    "./HUMAN_REQUEST_STATUSES": {
      "types": "./src/HUMAN_REQUEST_STATUSES.ts",
      "default": "./src/HUMAN_REQUEST_STATUSES.ts"
    },
    "./HumanRequestStatus": {
      "types": "./src/HumanRequestStatus.ts",
      "default": "./src/HumanRequestStatus.ts"
    },
    "./buildHumanRequestId": {
      "types": "./src/buildHumanRequestId.ts",
      "default": "./src/buildHumanRequestId.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
