{
  "name": "@smithers/tools",
  "version": "0.0.0",
  "description": "Built-in AI SDK tools and sandboxed file/process operations for Smithers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/core": "workspace:*",
    "@smithers/runtime": "workspace:*",
    "@smithers/observability": "workspace:*",
    "ai": "^6.0.69",
    "zod": "^4.3.6",
    "@effect/platform": "^0.96.0",
    "diff": "^5.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
