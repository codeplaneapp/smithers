{
  "name": "@smithers/agents",
  "version": "0.0.0",
  "description": "AI SDK and CLI agent adapters for Smithers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/core": "workspace:*",
    "@smithers/runtime": "workspace:*",
    "@smithers/observability": "workspace:*",
    "ai": "^6.0.69",
    "@ai-sdk/anthropic": "^3.0.36",
    "@ai-sdk/openai": "^3.0.41",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
