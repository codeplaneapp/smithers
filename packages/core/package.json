{
  "name": "@smithers/core",
  "version": "0.0.0",
  "description": "Compatibility exports for split Smithers core packages",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./context": {
      "types": "./src/context.ts",
      "default": "./src/context.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "default": "./src/errors.ts"
    },
    "./errors/index": {
      "types": "./src/errors.ts",
      "default": "./src/errors.ts"
    },
    "./errors/tagged": {
      "types": "./src/errors-tagged.ts",
      "default": "./src/errors-tagged.ts"
    },
    "./graph": {
      "types": "./src/graph.ts",
      "default": "./src/graph.ts"
    },
    "./RetryPolicy": {
      "types": "./src/RetryPolicy.ts",
      "default": "./src/RetryPolicy.ts"
    },
    "./CachePolicy": {
      "types": "./src/CachePolicy.ts",
      "default": "./src/CachePolicy.ts"
    },
    "./utils/*": {
      "types": "./src/utils/*.ts",
      "default": "./src/utils/*.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/driver": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/graph": "workspace:*",
    "@smithers/scheduler": "workspace:*",
    "effect": "^3.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
