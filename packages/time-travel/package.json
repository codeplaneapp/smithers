{
  "name": "@smithers/time-travel",
  "version": "0.0.0",
  "description": "Smithers snapshots, diffs, forks, replay, timelines, and VCS-tagged run history",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./snapshot": {
      "types": "./src/snapshot/index.ts",
      "default": "./src/snapshot/index.ts"
    },
    "./metrics": {
      "types": "./src/metrics.ts",
      "default": "./src/metrics.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/core": "workspace:*",
    "@smithers/graph": "workspace:*",
    "@smithers/runtime": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/db": "workspace:*",
    "@smithers/vcs": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
