{
  "name": "@smithers/server",
  "version": "0.0.0",
  "description": "HTTP, WebSocket, gateway, cron, webhook, and metrics servers for Smithers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*.js",
      "default": "./src/*.js",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/workflow": "^0.18.0",
    "@smithers/components": "workspace:*",
    "@smithers/db": "workspace:*",
    "@smithers/driver": "workspace:*",
    "@smithers/engine": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/scheduler": "workspace:*",
    "@smithers/time-travel": "workspace:*",
    "cron-parser": "^5.5.0",
    "effect": "^3.21.0",
    "hono": "^4.12.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
