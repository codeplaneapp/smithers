{
  "name": "@smithers/react-reconciler",
  "version": "0.0.0",
  "description": "Custom React reconciler that renders Smithers host trees",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js",
      "types": "./src/index.ts"
    },
    "./context": {
      "import": "./src/context.js",
      "default": "./src/context.js",
      "types": "./src/context.ts"
    },
    "./devtools": {
      "import": "./src/devtools/index.js",
      "default": "./src/devtools/index.js",
      "types": "./src/devtools/index.ts"
    },
    "./devtools/preload": {
      "import": "./src/devtools/preload.js",
      "default": "./src/devtools/preload.js"
    },
    "./driver": {
      "import": "./src/driver.js",
      "default": "./src/driver.js",
      "types": "./src/driver.ts"
    },
    "./jsx-runtime": {
      "import": "./src/jsx-runtime.js",
      "default": "./src/jsx-runtime.js",
      "types": "./src/jsx-runtime.ts"
    },
    "./*": {
      "import": "./src/*.js",
      "default": "./src/*.js",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/devtools": "workspace:*",
    "@smithers/driver": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/graph": "workspace:*",
    "react": "^18.3.0 || ^19.0.0",
    "react-reconciler": "^0.31.0",
    "bippy": "^0.5.32"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
