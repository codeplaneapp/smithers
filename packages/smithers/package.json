{
  "name": "smithers",
  "version": "0.0.0",
  "description": "Public Smithers facade and workflow authoring convenience package",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*.js",
      "default": "./src/*.js",
      "types": "./src/*.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./src/jsx-runtime.js",
      "default": "./src/jsx-runtime.js",
      "types": "./src/jsx-runtime.ts"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@smithers/agents": "workspace:*",
    "@smithers/db": "workspace:*",
    "@smithers/driver": "workspace:*",
    "@smithers/engine": "workspace:*",
    "@smithers/errors": "workspace:*",
    "@smithers/graph": "workspace:*",
    "@smithers/memory": "workspace:*",
    "@smithers/observability": "workspace:*",
    "@smithers/openapi": "workspace:*",
    "@smithers/components": "workspace:*",
    "@smithers/react-reconciler": "workspace:*",
    "@smithers/sandbox": "workspace:*",
    "@smithers/scheduler": "workspace:*",
    "@smithers/scorers": "workspace:*",
    "@smithers/server": "workspace:*",
    "@smithers/time-travel": "workspace:*",
    "@smithers/vcs": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9.3"
  }
}
