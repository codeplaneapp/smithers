{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "smithers": [
        "./packages/smithers/src/examples-entry.js"
      ],
      "smithers/jsx-runtime": [
        "./packages/smithers/src/jsx-runtime.js"
      ],
      "smithers/jsx-dev-runtime": [
        "./packages/smithers/src/jsx-runtime.js"
      ],
      "smithers/tools": [
        "./packages/smithers/src/tools/index.js"
      ],
      "smithers-orchestrator": [
        "./packages/smithers/src/examples-entry.js"
      ],
      "smithers-orchestrator/tools": [
        "./packages/smithers/src/tools/index.js"
      ]
    },
    "allowJs": true
  },
  "include": [
    "examples/**/*",
    "packages/smithers/src/examples-entry.ts",
    "packages/smithers/src/**/*"
  ],
  "exclude": [
    "packages/smithers/tests/**/*",
    "packages/smithers/src/pi-plugin/**/*",
    "packages/smithers/src/devtools/**/*"
  ]
}
